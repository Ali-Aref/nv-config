{
	"JSX Comment": {
		"prefix": "bcc",
		"description": "jsx comment",
		"body": "{/* ${1:comment} */}"
	},
	"Docstring": {
		"prefix": "docstr",
		"description": "Docstring for classes or functions",
		"body": [
			"/**",
			"* ${1:description}",
			"* @param {${2:type}} {${3:parmName}} - ${4:description}",
			"* @returns {${5:type}}",
			"*/"
		]
	}
}
